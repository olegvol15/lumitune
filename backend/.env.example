NODE_ENV=development
PORT=3000

# Required
MONGODB_URI=mongodb://127.0.0.1:27017/lumitune
JWT_SECRET=replace-with-a-long-random-user-secret

# URLs
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# Auth tokens
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
ADMIN_JWT_SECRET=replace-with-a-long-random-admin-secret
ADMIN_JWT_EXPIRES_IN=15m
ADMIN_REFRESH_TOKEN_EXPIRES_DAYS=30

# Password reset codes
RESET_CODE_EXPIRES_MINUTES=10
ADMIN_RESET_CODE_EXPIRES_MINUTES=10

# Uploads
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=524288000

# Email
APP_NAME=LumiTune
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
